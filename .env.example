# ─────────────────────────────────────────────────────────────────────────────
# WMIND Edge Gateway – environment variable template
# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Logging ───────────────────────────────────────────────────────────────────
LOGGING_LEVEL_DEFAULT=Information
LOGGING_LEVEL_MICROSOFT=Warning

# ── Modbus TCP ────────────────────────────────────────────────────────────────
MODBUS_MAX_CONCURRENT_POLLS=10
MODBUS_FAILURE_THRESHOLD=3

# ── Modbus RTU ────────────────────────────────────────────────────────────────
MODBUS_RTU_FAILURE_THRESHOLD=2
MODBUS_RTU_INTERFRAME_GAP_MS=5
MODBUS_RTU_RESPONSE_TIMEOUT_MS=3000
MODBUS_RTU_DATA_BITS=8
MODBUS_RTU_STOP_BITS=1

# ── InfluxDB ──────────────────────────────────────────────────────────────────
# URL seen by the edge-gateway container (service name, not localhost)
INFLUXDB_URL=http://influxdb:8086
# Admin token – set ONCE during first InfluxDB init; use same value afterward
INFLUXDB_TOKEN=CHANGE_ME_INFLUX_TOKEN
INFLUXDB_ORG=Wonderbiz
INFLUXDB_BUCKET=SignalGateway
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_INFLUX_ADMIN_PASS
# Host port InfluxDB is exposed on (maps to container 8086)
INFLUXDB_HOST_PORT=8087

# ── M2M ───────────────────────────────────────────────────────────────────────
M2M_CLIENT_ID=my-client-id
M2M_CLIENT_SECRET=CHANGE_ME_M2M_SECRET
M2M_TOKEN_URL=https://authserver.com/oauth/token
M2M_API_URL=https://cloudapp.com/api/telemetry
M2M_CONFIG_URL=https://cloudapp.com/api/deviceConfigs

# ── Gateway identity ──────────────────────────────────────────────────────────
GATEWAY_CLIENT_ID=GW-f2182b6d81284f1b88eebb834fdeba99
GATEWAY_CLIENT_SECRET=CHANGE_ME_GATEWAY_SECRET

# ── Auth & Device API ─────────────────────────────────────────────────────────
# Point to your on-prem auth/API server (reachable from Docker network)
AUTH_BASE_URL=http://10.10.10.209:5000/
DEVICE_API_BASE_URL=http://10.10.10.209:5000/

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_CONFIGURATIONS_MINUTES=30

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME_RABBIT_PASS
RABBITMQ_POLL_INTERVAL_SECONDS=5
# Host ports
RABBITMQ_AMQP_HOST_PORT=5672
RABBITMQ_MGMT_HOST_PORT=15672
